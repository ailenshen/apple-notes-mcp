{
  "name": "@ailenshen/apple-notes-mcp",
  "version": "1.3.3",
  "description": "Apple Notes MCP Server",
  "repository": {
    "type": "git",
    "url": "https://github.com/ailenshen/apple-notes-mcp"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "apple-notes-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "start": "node dist/index.js",
    "test": "tsc -p tsconfig.test.json && node --test --test-isolation=none --test-reporter=spec --test-reporter-destination=stderr .dist-test/test/*.test.js && node .dist-test/test/e2e.js",
    "test:unit": "tsc -p tsconfig.test.json && node --test --test-isolation=none --test-reporter=spec --test-reporter-destination=stderr .dist-test/test/*.test.js",
    "test:e2e": "tsc -p tsconfig.test.json && node .dist-test/test/e2e.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^5.2.1",
    "turndown": "^7.2.2"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "@types/turndown": "^5.0.6",
    "typescript": "^5.8.3"
  }
}
